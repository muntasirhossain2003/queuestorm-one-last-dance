# QueueStorm Investigator — environment variable reference.
# Copy this to .env and fill in real values. Never commit .env to git.

# Port the service binds to (most PaaS platforms inject this automatically).
PORT=8000

# ── Analysis mode ──────────────────────────────────────────────────────────
# rule   → fully deterministic, no API key needed (default, always safe)
# groq   → Groq free tier (Llama-3.3-70b); get key at console.groq.com
# gemini → Google Gemini free tier (1.5-Flash); get key at aistudio.google.com
ANALYZER_MODE=rule

# ── Groq (free tier, ~14 400 req/day) ──────────────────────────────────────
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile   # or llama-3.1-8b-instant for lower latency

# ── Google Gemini (free tier, 15 RPM) ──────────────────────────────────────
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash         # or gemini-2.0-flash
