# QueueStorm Investigator — environment variable reference.
# Copy this to .env and fill in real values. Never commit .env to git.

# Port the service binds to (most PaaS platforms inject this automatically).
PORT=8000

# ── Analysis mode ──────────────────────────────────────────────────────────
# cascade → Groq first, Gemini fallback, rule-based last resort (recommended)
# groq    → Groq only
# gemini  → Gemini only
# rule    → fully deterministic, no API key needed (default)
ANALYZER_MODE=cascade

# ── Groq (free tier, ~14 400 req/day per key) ────────────────────────────────
# Comma-separate multiple keys — when one hits its rate limit the next is used.
# GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3
# GROQ_MODEL=llama-3.3-70b-versatile   # or llama-3.1-8b-instant for lower latency

# ── Google Gemini (free tier, 15 RPM per key) ────────────────────────────────
# Comma-separate multiple keys for higher effective throughput.
# GEMINI_API_KEY=AIza_key1,AIza_key2,AIza_key3
# GEMINI_MODEL=gemini-1.5-flash         # or gemini-2.0-flash
